{
  "name": "kurnool-mall",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@kurnool-mall/web",
    "dev:customer": "turbo run dev --filter=@kurnool-mall/mobile-customer",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@kurnool-mall/web",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "cd supabase && supabase db push",
    "db:seed": "tsx supabase/seed/index.ts",
    "db:reset": "cd supabase && supabase db reset"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.5.0"
}
